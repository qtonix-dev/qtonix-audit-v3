<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{report.businessName}} — Site Analysis</title>
<style>
/* ===========================================================================
   Qtonix Site Analysis — exact match to the reference proposal design.
   Every value below was measured from the reference PDF, not estimated:
     page      US Letter (612x792pt), 0.87in side margins
     cover     linear-gradient #0A0E28 -> #0435AC, full bleed
     navy      #0A0E27        headline blue #005AFF
     accent    #B4FF24 (lime) -> REPLACED BY #FF6A00 (orange) per brief
     stat red  #E5484D        quote tint #EEF3FF
   Rendered with WeasyPrint 69.0 — the same engine that produced the reference.
   =========================================================================== */

{{#if forWeb}}
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap');
{{else}}
@font-face { font-family:'Plus Jakarta Sans'; src:url('{{fontDir}}/PlusJakartaSans-Regular.ttf'); font-weight:400; }
@font-face { font-family:'Plus Jakarta Sans'; src:url('{{fontDir}}/PlusJakartaSans-Medium.ttf'); font-weight:500; }
@font-face { font-family:'Plus Jakarta Sans'; src:url('{{fontDir}}/PlusJakartaSans-Bold.ttf'); font-weight:700; }
@font-face { font-family:'Plus Jakarta Sans'; src:url('{{fontDir}}/PlusJakartaSans-ExtraBold.ttf'); font-weight:800; }
{{/if}}

:root{
  --navy:{{settings.colors.navy}};
  --accent:{{settings.colors.orange}};
  --accent-deep:{{settings.colors.orangeDeep}};
  --blue:{{settings.colors.blue}};
  --ink:#0A0E27;
  --muted:#6B7280;
  --line:#E5E7EB;
  --red:#E5484D;
  --tint:#EEF3FF;
  --tint-accent:#FFF4EC;
}

{{#if forWeb}}
/* Screen presentation is defined at the end of this stylesheet so it reliably
   overrides the print rules above. */
{{/if}}

@page{ size: Letter; margin: 0; }

@page interior{
  size: Letter;
  /* Footer removed. The bottom margin was 0.95in mainly to clear the running
     footer; with the footer gone we match the top (0.87in) so content that
     was spilling to a near-blank next page now fits on its own page. */
  margin: 0.87in 0.88in 0.87in 0.87in;
}

*{ margin:0; padding:0; box-sizing:border-box; }
body{ font-family:'Plus Jakarta Sans', sans-serif; color:var(--ink); font-size:9.5pt; line-height:1.55; }

/* ---------------- COVER ---------------- */
.cover{
  width:8.5in; height:11in;
  padding:1.1in 0.88in 0.9in 0.87in;
  background:linear-gradient(180deg,#0A0E28 0%,#0435AC 100%);
  color:#fff; position:relative;
  page-break-after:always;
}
.cover-top{ display:flex; justify-content:space-between; align-items:center; }
.logo-img{ height:38px; }
.logo-text{ font-size:22pt; font-weight:800; letter-spacing:-.5px; }
.logo-text .dot{ color:var(--accent); }
.cover-svc{ font-size:7.5pt; letter-spacing:2.5px; font-weight:500; color:rgba(255,255,255,.85); }

.rule-accent{ height:2px; background:var(--accent); margin-top:20px; }
.eyebrow{ margin-top:14px; font-size:7.5pt; letter-spacing:2.8px; font-weight:700; color:var(--accent); }
.dia{ display:inline-block; width:8px; height:8px; background:var(--accent); transform:rotate(45deg); margin-right:8px; }
.rule-faint{ height:1px; background:rgba(255,255,255,.22); margin-top:14px; }

.cover h1{ font-size:36pt; line-height:1.08; letter-spacing:-1.4px; font-weight:800; margin-top:34px; }
.cover h1 .lt{ font-weight:400; color:rgba(255,255,255,.68); }
.cover-sub{ margin-top:22px; font-size:10.5pt; line-height:1.62; color:rgba(255,255,255,.8); max-width:5.7in; }
.cover-div{ height:1px; background:rgba(255,255,255,.22); margin-top:50px; }

.cov-lab{ font-size:7.5pt; letter-spacing:2.2px; font-weight:700; color:rgba(255,255,255,.6); margin-top:24px; }
.cov-client{ font-size:19pt; font-weight:800; margin-top:8px; letter-spacing:-.4px; hyphens:none; }
.cov-detail{ font-size:9pt; color:rgba(255,255,255,.7); margin-top:5px; }

.pills{ margin-top:22px; }
.pill{ display:inline-block; background:var(--accent); color:var(--navy); font-weight:800;
  font-size:8.5pt; padding:8px 20px; border-radius:999px; margin-right:8px; }

.cover-foot{ position:absolute; left:0.87in; right:0.88in; bottom:0.9in;
  display:flex; justify-content:space-between; font-size:8pt; color:rgba(255,255,255,.6); }
.cover-foot b{ color:#fff; font-weight:700; }

/* ---------------- INTERIOR ---------------- */
.page{ page:interior; page-break-after:always; }
.page:last-child{ page-break-after:auto; }

.sec-head{ margin-bottom:14px; font-size:7.5pt; }
.sec-dia{ display:inline-block; width:8px; height:8px; background:var(--blue); transform:rotate(45deg); margin-right:9px; }
/* Reference uses BLUE for interior section markers; the accent colour is reserved for the cover, pills and CTA. Verified by pixel-sampling the source PDF. */
.sec-num{ color:var(--blue); font-weight:800; font-size:9pt; margin-right:9px; }
.sec-rule{ display:inline-block; width:34px; height:1px; background:var(--blue); vertical-align:middle; margin-right:9px; }
.sec-name{ letter-spacing:2.6px; font-weight:700; color:var(--muted); }

h2{ font-size:20pt; line-height:1.2; letter-spacing:-.6px; font-weight:800; margin-bottom:14px; }
h2 .b{ color:var(--blue); }
h3{ font-size:10.5pt; font-weight:700; margin:22px 0 9px; }
p{ margin-bottom:9px; }
.lead{ color:#374151; font-size:9.5pt; line-height:1.62; }

.toc-row{ padding:11px 0; border-bottom:1px solid var(--line); }
.toc-n{ color:var(--blue); font-weight:800; font-size:8.5pt; display:inline-block; width:34px; }
.toc-t{ font-weight:700; font-size:9.5pt; }

.stats{ display:flex; gap:10px; margin:18px 0; }
.stat{ flex:1; border:1px solid var(--line); border-radius:9px; padding:14px; }
.stat-v{
  font-size:23pt; font-weight:800; line-height:1; letter-spacing:-1px;
  /* Stat values are single tokens: "20–30%", "~210", "0.2". WeasyPrint will
     happily break after an en-dash or before a tilde, which looks broken.
     Belt and braces: forbid wrapping, and shrink rather than wrap if a very
     long value ever appears. */
  white-space:nowrap;
  overflow-wrap:normal;
  hyphens:none;
}
.stat-v.bad{ color:var(--red); } .stat-v.warn{ color:#E58A24; }
.stat-v.good{ color:#16A34A; }   .stat-v.ink{ color:var(--ink); }
.stat-l{ font-size:7.5pt; color:var(--muted); margin-top:9px; line-height:1.45; }

table{ width:100%; border-collapse:collapse; font-size:8.5pt; margin:10px 0; }
thead th{ background:var(--navy); color:#fff; text-align:left; padding:9px 10px; font-weight:700; font-size:8pt; }
tbody td{ padding:9px 10px; border-bottom:1px solid var(--line); vertical-align:top; }
tbody tr:nth-child(even){ background:#FAFBFC; }
.tb{ font-weight:700; }

.badge{ display:inline-block; padding:2px 7px; border-radius:999px; font-size:6.5pt; font-weight:700; }
.b-crit{ background:#FDE8E8; color:#9B1C1C; }
.b-warn{ background:#FEF3C7; color:#92400E; }
.b-note{ background:#E0E7FF; color:#3730A3; }
.b-good{ background:#DCFCE7; color:#166534; }
.b-you{ background:var(--tint-accent); color:var(--accent-deep); }

.two{ display:flex; gap:12px; margin:16px 0; }
.box{ flex:1; border-radius:9px; padding:15px; }
.box-bad{ background:#FDF2F2; border:1px solid #FBD5D5; }
.box-good{ background:var(--tint-accent); border:1px solid #FFD9BF; }
.box h4{ font-size:7.5pt; letter-spacing:1.6px; font-weight:800; margin-bottom:10px; }
.box-bad h4{ color:var(--red); } .box-good h4{ color:var(--accent-deep); }
.box li{ list-style:none; font-size:8.5pt; margin-bottom:8px; padding-left:11px; position:relative; line-height:1.5; }
.box li:before{ content:'•'; position:absolute; left:0; }
.box-bad li:before{ color:var(--red); } .box-good li:before{ color:var(--accent-deep); }

.quote{ background:var(--tint); border-radius:9px; padding:20px 24px; text-align:center; margin:18px 0; }
.quote .qd{ display:block; width:9px; height:9px; background:var(--blue); transform:rotate(45deg); margin:0 auto 14px; }
.quote p{ font-style:italic; font-size:10.5pt; color:#1E293B; margin:0; line-height:1.5; }
.quote.accent{ background:var(--tint-accent); }
.quote.accent .qd{ background:var(--accent); }

.bar-row{ display:flex; align-items:center; gap:10px; margin-bottom:8px; font-size:8pt; }
.bar-lab{ width:1.5in; text-align:right; color:#4B5563; }
.bar-track{ flex:1; height:18px; }
.bar-fill{ height:100%; border-radius:2px; }
.bar-you{ background:var(--blue); }
.bar-them{ background:#C6CBD4; }
.bar-val{ font-size:7.5pt; font-weight:800; width:.6in; }

.kpi{ display:flex; flex-wrap:wrap; gap:10px; margin:14px 0; }
.kpi-c{ width:31.5%; border:1px solid var(--line); border-radius:9px; padding:13px; }
.kpi-l{ font-size:6.5pt; letter-spacing:1.1px; font-weight:700; color:var(--muted); margin-bottom:8px; }
.kpi-v{ font-size:11.5pt; font-weight:800; white-space:nowrap; hyphens:none; }
.kpi-f{ color:var(--red); } .kpi-t{ color:var(--blue); }
.kpi-bar{ height:4px; background:#EEF1F5; border-radius:2px; margin-top:10px; }
.kpi-fill{ height:100%; border-radius:2px; background:linear-gradient(90deg,var(--blue),var(--accent)); }

.step{ display:flex; gap:12px; border:1px solid var(--line); border-radius:9px; padding:12px; margin-bottom:8px; }
.step-n{ width:26px; height:26px; border-radius:6px; background:var(--navy); color:#fff;
  text-align:center; line-height:26px; font-weight:800; font-size:9pt; flex-shrink:0; }
.step-t{ font-weight:700; font-size:9.5pt; }
.step-d{ font-size:8.5pt; color:var(--muted); margin-top:2px; }

.cta{ background:linear-gradient(135deg,#0A0E28,#0435AC); border-radius:12px; padding:30px; text-align:center; color:#fff; margin-top:18px; }
.cta-e{ font-size:7.5pt; letter-spacing:2.6px; font-weight:700; color:var(--accent); }
.cta h3{ font-size:18pt; font-weight:800; margin:10px 0; color:#fff; }
.cta p{ font-size:9.5pt; color:rgba(255,255,255,.8); margin:0 auto 18px; max-width:4.6in; }
.cta-b{ display:inline-block; background:var(--accent); color:var(--navy); font-weight:800; padding:13px 34px; border-radius:999px; font-size:10pt; }
.cta-s{ font-size:8pt; color:rgba(255,255,255,.62); margin-top:16px; line-height:1.6; }

.note{ font-size:7.5pt; color:#9AA3B2; font-style:italic; margin-top:12px; line-height:1.5; }
.nb{ background:#F8FAFC; border-left:3px solid var(--blue); padding:12px 14px; margin:14px 0; font-size:8pt; color:#475569; line-height:1.55; }
.avoid{ page-break-inside:avoid; }

/* ---------------- PRICING ---------------- */
.price-grid{ display:flex; gap:12px; margin:22px 0 16px; align-items:stretch; }
.pk{ flex:1; border:1px solid var(--line); border-radius:11px; padding:18px 16px; position:relative; }
/* The featured card gets the blue border and sits slightly proud, exactly as
   the reference does. The RECOMMENDED tab overlaps the top edge. */
.pk.feat{ border:2px solid var(--blue); }
.pk-tab{ position:absolute; top:-11px; left:50%; transform:translateX(-50%);
  background:var(--accent); color:var(--navy); font-size:6.5pt; font-weight:800;
  letter-spacing:1.2px; padding:4px 14px; border-radius:999px; white-space:nowrap; }
.pk-name{ font-size:7.5pt; letter-spacing:2px; font-weight:800; color:var(--muted); }
.pk-price{ font-size:26pt; font-weight:800; letter-spacing:-1.5px; margin-top:10px;
  color:var(--blue); white-space:nowrap; line-height:1; }
.pk-per{ font-size:8.5pt; font-weight:500; color:var(--muted); }
.pk-old{ font-size:9pt; color:#B6BECD; text-decoration:line-through; margin-top:4px; }
.pk-blurb{ font-size:8pt; color:#475569; line-height:1.5; margin-top:12px;
  padding-top:12px; border-top:1px solid var(--line); }
.pk-f{ list-style:none; margin-top:12px; }
.pk-f li{ font-size:7.5pt; line-height:1.45; margin-bottom:7px; padding-left:13px; position:relative; color:#334155; }
.pk-f li:before{ content:'✓'; position:absolute; left:0; color:var(--blue); font-weight:800; }
.pk-f li.star{ color:var(--accent-deep); font-weight:700; }
.pk-f li.star:before{ content:'★'; color:var(--accent); }

.risk{ background:linear-gradient(135deg,#0A0E28,#0435AC); border-radius:11px;
  padding:20px 24px; color:#fff; margin-top:14px; display:flex; gap:16px; align-items:center; }
.risk-i{ flex-shrink:0; line-height:0; }
.risk-t{ font-size:11.5pt; font-weight:800; color:var(--accent); }
.risk-b{ font-size:8.5pt; color:rgba(255,255,255,.85); line-height:1.55; margin-top:5px; }
{{#if forWeb}}
/* ============ SCREEN-ONLY (browser "view") — overrides print rules ============
   The PDF is unaffected (it never sets forWeb). In print, interior page margins
   come from @page interior {}, which browsers ignore — so on screen we give
   .page an explicit size and inner padding, or content sprawls edge-to-edge. */
body{ background:#525659; margin:0; padding:24px 0; }
.page{
  width:8.5in; min-height:11in;
  margin:0 auto 24px auto;
  padding:0.87in 0.88in 0.87in 0.87in;   /* == @page interior margins */
  box-shadow:0 4px 24px rgba(0,0,0,.35);
  background:#fff;
  overflow:hidden;
}
.cover{ margin:0 auto 24px auto; box-shadow:0 4px 24px rgba(0,0,0,.35); }
{{/if}}
</style>
</head>
<body>

<!-- ================= COVER ================= -->
<div class="cover">
  <div class="cover-top">
    {{#if settings.logoPath}}<img class="logo-img" src="{{settings.logoPath}}" alt="{{settings.companyShort}}">
    {{else}}<div class="logo-text">{{settings.companyShort}}<span class="dot">.</span></div>{{/if}}
    <div class="cover-svc">SEO · AI SEO · GEO · AEO</div>
  </div>

  <div class="rule-accent"></div>
  <div class="eyebrow"><span class="dia"></span>COMPLETE SITE ANALYSIS</div>
  <div class="rule-faint"></div>

  <h1>{{headline.headlineBold}}<br><span class="lt">{{headline.headlineLight}}</span></h1>
  <div class="cover-sub">{{headline.subhead}}</div>

  <div class="cover-div"></div>

  <div class="cov-lab">PREPARED FOR</div>
  <div class="cov-client">{{report.businessName}} — {{report.customerName}}</div>
  <div class="cov-detail">{{report.industryLine}} · {{report.domain}}{{#if report.location}} · {{report.location}}{{/if}}</div>

  <div class="pills">{{#each report.services}}<span class="pill">{{this}}</span>{{/each}}</div>

  <div class="cover-foot">
    <div>Prepared by <b>{{report.agentName}}</b> · {{settings.companyName}}</div>
    <div>{{formatDate report.date}} · Valid {{report.validDays}} days</div>
  </div>
</div>

<!-- ================= CONTENTS ================= -->
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-rule"></span><span class="sec-name">CONTENTS</span></div>
  <h2>What's <span class="b">inside.</span></h2>
  <p class="lead">A precise, evidence-based look at where {{report.domain}} stands in search today, why customers aren't finding it, and the specific plan to change that. No hype — just the data and the roadmap.</p>
  <div style="margin-top:26px">
    {{#each toc}}<div class="toc-row"><span class="toc-n">{{this.n}}</span><span class="toc-t">{{this.t}}</span></div>{{/each}}
  </div>
</div>

<!-- ================= 01 THE SITUATION ================= -->
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">01</span><span class="sec-rule"></span><span class="sec-name">THE SITUATION</span></div>
  <h2>{{summary.headA}} <span class="b">{{summary.headB}}</span></h2>
  <p class="lead">{{summary.verdict}}</p>
  <p class="lead">{{summary.diagnosis}}</p>

  <div class="stats">
    <div class="stat"><div class="stat-v {{toneFor backlinks.domainAuthority 30 60}}">{{backlinks.domainAuthority}}</div>
      <div class="stat-l">Domain Authority — competitors average {{competitorAvgDA}}</div></div>
    <div class="stat"><div class="stat-v {{toneFor keywordData.page1Keywords 1 10}}">{{keywordData.page1Keywords}}</div>
      <div class="stat-l">Keywords ranking on page 1 — customers can't find you</div></div>
    <div class="stat"><div class="stat-v ink">~{{formatNum keywordData.traffic}}</div>
      <div class="stat-l">Est. monthly organic visits — a fraction of the demand</div></div>
    <div class="stat"><div class="stat-v ink">{{formatNum crawl.wordCount}}</div>
      <div class="stat-l">Words on your homepage — content to build on</div></div>
  </div>

  <h3>What we researched about your business</h3>
  <table>
    <thead><tr><th style="width:24%">Factor</th><th>What we found</th></tr></thead>
    <tbody>{{#each research}}<tr><td class="tb">{{this.k}}</td><td>{{this.v}}</td></tr>{{/each}}</tbody>
  </table>

  <div class="quote"><span class="qd"></span><p>{{summary.opportunity}}</p></div>

  <div class="note">A note on this data. All data in this report is sourced from third-party tools and our own crawl of {{report.domain}}, as we currently do not have direct access to your website, Google Search Console, or Analytics. Any discrepancies or inaccuracies in data may be due to this.</div>
</div>

<!-- ================= 02 THE VISIBILITY GAP ================= -->
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">02</span><span class="sec-rule"></span><span class="sec-name">THE VISIBILITY GAP</span></div>
  <h2>The demand is real and measurable. <span class="b">You're simply not in the results yet.</span></h2>
  <p class="lead">{{visibility.intro}}</p>

  <h3>Estimated monthly organic traffic — you vs. competitors</h3>
  <p class="note" style="margin:0 0 12px">Source: SE Ranking, {{formatMonth report.date}}. Log scale. Your bar in blue.</p>
  {{#each trafficBars}}
  <div class="bar-row">
    <div class="bar-lab">{{this.label}}</div>
    <div class="bar-track"><div class="bar-fill {{#if this.isYou}}bar-you{{else}}bar-them{{/if}}" style="width:{{this.pct}}%"></div></div>
    <div class="bar-val">{{formatNum this.value}}</div>
  </div>
  {{/each}}

  {{#if strikingTop.length}}
  <h3>High-intent searches: where you rank now vs. where we'll take you</h3>
  <p class="note" style="margin:0 0 12px">Source: SE Ranking, {{formatMonth report.date}}. These already sit in positions 11–20 — one push from page one.</p>
  <table>
    <thead><tr><th style="width:40%">Keyword</th><th>Now</th><th>Target</th><th>Searches/mo</th><th>Value if page 1</th></tr></thead>
    <tbody>
      {{#each strikingTop}}
      <tr><td class="tb">{{this.keyword}}</td>
        <td style="color:#E5484D;font-weight:700">{{this.position}}</td>
        <td style="color:{{../settings.colors.blue}};font-weight:700">{{this.target}}</td>
        <td>{{formatNum this.volume}}</td>
        <td class="tb">{{currency this.gain}}/mo</td></tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  <div class="quote accent"><span class="qd"></span><p>{{visibility.quote}}</p></div>
</div>

<!-- ================= 03 PROBLEM & TRANSFORMATION ================= -->
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">03</span><span class="sec-rule"></span><span class="sec-name">PROBLEM &amp; TRANSFORMATION</span></div>
  <h2>It's fixable. <span class="b">Here's the honest diagnosis and what changes.</span></h2>

  <div class="two">
    <div class="box box-bad"><h4>◆ THE PROBLEM TODAY</h4>
      <ul>{{#each problemsToday}}<li>{{this}}</li>{{/each}}</ul></div>
    <div class="box box-good"><h4>✓ AFTER WE'RE DONE</h4>
      <ul>{{#each afterFix}}<li>{{this}}</li>{{/each}}</ul></div>
  </div>

  <div class="stats" style="margin-top:20px">
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.orangeDeep}}">{{growth.lift}}</div>
      <div class="stat-l">Targeted lift in traffic &amp; enquiries within 90 days</div></div>
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.orangeDeep}}">3</div>
      <div class="stat-l">Phase plan: Clean-up → Build pages → Scale authority</div></div>
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.orangeDeep}}">{{growth.multiple}}</div>
      <div class="stat-l">Projected targeted visits by month 12 vs. today</div></div>
    <div class="stat"><div class="stat-v ink">{{issueCounts.total}}</div>
      <div class="stat-l">Issues found — {{issueCounts.critical}} critical</div></div>
  </div>

  <h3>The measurable result — first 3 months</h3>
  <p class="lead">Our target for the first 90 days is a <strong>{{growth.lift}} increase in targeted traffic and enquiries</strong>, establishing the authority and page structure for compounding growth after that.</p>

  {{#if roadmap.quickWins.length}}
  <div class="box box-good" style="margin-top:16px">
    <h4>◆ THREE THINGS YOU CAN FIX THIS WEEK — WITHOUT US</h4>
    <ul>{{#each roadmap.quickWins}}<li><strong>{{this.title}}</strong> — {{this.detail}}</li>{{/each}}</ul>
  </div>
  {{/if}}
</div>

<!-- ================= 04 HEALTH SCORECARD ================= -->
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">04</span><span class="sec-rule"></span><span class="sec-name">HEALTH SCORECARD</span></div>
  <h2>Six things decide whether you get found. <span class="b">Here's where you stand.</span></h2>
  <p class="lead">Every score comes from a live measurement of {{report.domain}}, not an opinion. Red means it is actively costing you customers today.</p>

  <div style="text-align:center;margin:20px 0">
    <svg width="150" height="150" viewBox="0 0 150 150">
      <circle cx="75" cy="75" r="62" fill="none" stroke="#EEF1F5" stroke-width="13"/>
      <circle cx="75" cy="75" r="62" fill="none" stroke="{{scoreColor scores.overall}}" stroke-width="13"
              stroke-linecap="round" stroke-dasharray="{{ringDash scores.overall 62}}" transform="rotate(-90 75 75)"/>
      <text x="75" y="72" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="36" font-weight="800" fill="{{scoreColor scores.overall}}">{{scores.overall}}</text>
      <text x="75" y="90" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="9" fill="#6B7280">out of 100</text>
    </svg>
    <div style="font-size:7.5pt;letter-spacing:2px;font-weight:700;color:#6B7280;margin-top:4px">OVERALL HEALTH SCORE</div>
  </div>

  <table>
    <thead><tr><th style="width:24%">Area</th><th style="width:11%">Score</th><th>What it means</th></tr></thead>
    <tbody>
      {{#each dials}}
      <tr><td class="tb">{{this.name}}</td>
        <td style="color:{{this.color}};font-weight:800;font-size:11pt">{{this.score}}</td>
        <td>{{this.verdict}}</td></tr>
      {{/each}}
    </tbody>
  </table>

  <h3>Your critical issues</h3>
  <table>
    <thead><tr><th style="width:11%">Severity</th><th style="width:36%">Issue</th><th>Why it matters</th></tr></thead>
    <tbody>
      {{#each topIssues}}
      <tr><td><span class="badge {{severityClass this.severity}}">{{upper this.severity}}</span></td>
        <td class="tb">{{this.title}}</td><td>{{this.detail}}</td></tr>
      {{/each}}
    </tbody>
  </table>
  {{#if moreIssues}}<p class="note">…and {{moreIssues}} further issues documented in the full technical appendix, provided when we begin work.</p>{{/if}}
</div>

<!-- ================= 05 COMPETITOR & BACKLINK ================= -->
{{#if competitors.length}}
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">05</span><span class="sec-rule"></span><span class="sec-name">COMPETITOR &amp; BACKLINK ANALYSIS</span></div>
  <h2>Your competitors aren't better at what you do. <span class="b">They just have authority and the right pages.</span></h2>
  <p class="lead">{{competitorIntro}}</p>

  <div class="two">
    <div class="box box-bad"><h4>◆ WHERE YOU'RE LOSING</h4>
      <ul>{{#each losing}}<li>{{this}}</li>{{/each}}</ul></div>
    <div class="box box-good"><h4>✓ HOW WE WIN IT BACK</h4>
      <ul>{{#each winning}}<li>{{this}}</li>{{/each}}</ul></div>
  </div>

  <table>
    <thead><tr><th>Domain</th><th>Authority</th><th>Ref. domains</th><th>Keywords</th><th>Est. traffic/mo</th></tr></thead>
    <tbody>
      <tr style="background:#FFF4EC">
        <td class="tb">{{report.domain}} <span class="badge b-you">YOU</span></td>
        <td class="tb" style="color:#E5484D">{{backlinks.domainAuthority}}</td>
        <td>{{formatNum backlinks.referringDomains}}</td>
        <td>{{formatNum keywordData.totalKeywords}}</td>
        <td class="tb">{{formatNum keywordData.traffic}}</td>
      </tr>
      {{#each competitors}}
      <tr><td>{{this.domain}}</td><td class="tb">{{this.domainAuthority}}</td>
        <td>{{formatNum this.referringDomains}}</td><td>{{formatNum this.totalKeywords}}</td>
        <td>{{formatNum this.traffic}}</td></tr>
      {{/each}}
    </tbody>
  </table>
</div>

<div class="page">
  <h3 style="margin-top:0">Your backlink profile — {{formatNum backlinks.sampled}} linking websites analysed</h3>
  <p class="note" style="margin:0 0 10px">Source: SE Ranking, {{formatMonth report.date}}.{{#if backlinks.toxic}} Much of the profile is spam / low-quality — the cleanup priority.{{/if}}</p>

  <div style="text-align:center;margin:18px 0">
    <svg width="230" height="230" viewBox="0 0 230 230">
      {{#each donutArcs}}
      <circle cx="115" cy="115" r="84" fill="none" stroke="{{this.color}}" stroke-width="40"
              stroke-dasharray="{{this.dash}}" stroke-dashoffset="{{this.offset}}" transform="rotate(-90 115 115)"/>
      {{/each}}
      <circle cx="115" cy="115" r="64" fill="#fff"/>
      <text x="115" y="113" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="32" font-weight="800" fill="{{settings.colors.navy}}">{{formatNum backlinks.sampled}}</text>
      <text x="115" y="134" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" fill="#6B7280">linking sites</text>
    </svg>
  </div>

  <div style="text-align:center;font-size:9pt;margin-bottom:6px">
    <span style="margin:0 14px"><span style="display:inline-block;width:22px;height:6px;background:{{settings.colors.blue}};border-radius:2px;margin-right:6px"></span>Quality · {{backlinks.quality}}</span>
    <span style="margin:0 14px"><span style="display:inline-block;width:22px;height:6px;background:#C6CBD4;border-radius:2px;margin-right:6px"></span>Neutral · {{backlinks.neutral}}</span>
    <span style="margin:0 14px"><span style="display:inline-block;width:22px;height:6px;background:#E5484D;border-radius:2px;margin-right:6px"></span>Spam / toxic · {{backlinks.toxic}}</span>
  </div>

  {{#if backlinks.toxic}}
  <div class="nb"><strong>Priority fix — clean up the spammy backlinks.</strong> {{backlinks.toxic}} of your {{backlinks.sampled}} analysed linking sites score under 10 for authority — the signature of link farms and classified-ad directories. They add no authority and a little risk. We'll audit, disavow the junk, and build genuine, relevant links so your authority grows on a clean foundation.</div>
  {{/if}}

  {{#if keywordGapTop.length}}
  <h3>Keywords they rank for and you don't</h3>
  <table>
    <thead><tr><th style="width:44%">Keyword</th><th>Searches/mo</th><th>Their position</th><th>Difficulty</th></tr></thead>
    <tbody>{{#each keywordGapTop}}<tr><td class="tb">{{this.keyword}}</td><td>{{formatNum this.volume}}</td><td>{{this.position}}</td><td>{{this.difficulty}}/100</td></tr>{{/each}}</tbody>
  </table>
  <p class="note">This is a sample. The full gap analysis contains {{keywordGap.length}}+ terms your competitors own and you don't.</p>
  {{/if}}
</div>
{{/if}}

<!-- ================= 06 AI SEARCH VISIBILITY ================= -->
{{#if ai}}
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">06</span><span class="sec-rule"></span><span class="sec-name">AI SEARCH VISIBILITY</span></div>
  <h2>Your buyers don't only ask Google anymore. <span class="b">They ask ChatGPT too.</span></h2>
  <p class="lead">Search is changing fast. Customers increasingly ask ChatGPT, Google AI Overviews, Gemini, Perplexity and Claude for recommendations before they ever click. We asked an AI assistant {{ai.promptsTested}} real buying questions from your category — never mentioning your name — and recorded who it recommended.</p>

  <div class="stats">
    <div class="stat"><div class="stat-v {{toneFor ai.shareOfVoice 20 60}}">{{ai.mentions}}/{{ai.promptsTested}}</div>
      <div class="stat-l">Times you were recommended</div></div>
    <div class="stat"><div class="stat-v {{toneFor ai.shareOfVoice 20 60}}">{{ai.shareOfVoice}}%</div>
      <div class="stat-l">Your AI share of voice</div></div>
    <div class="stat"><div class="stat-v {{toneFor ai.readinessScore 40 75}}">{{ai.readinessScore}}%</div>
      <div class="stat-l">AI-readiness of your website</div></div>
    <div class="stat"><div class="stat-v bad">{{ai.aiOverview.gapCount}}</div>
      <div class="stat-l">Google AI Overviews answering without you</div></div>
  </div>

  {{#if ai.rivals.length}}
  <h3>Who the AI recommends instead</h3>
  <table>
    <thead><tr><th style="width:52%">Brand named by the AI</th><th>Times recommended</th><th>Out of</th></tr></thead>
    <tbody>{{#each ai.rivals}}<tr><td class="tb">{{this.name}}</td><td>{{this.count}}</td><td>{{this.outOf}} questions</td></tr>{{/each}}</tbody>
  </table>
  {{/if}}

  <h3>Why you're being skipped</h3>
  <table>
    <thead><tr><th style="width:9%">Status</th><th style="width:31%">Signal</th><th>What it means</th></tr></thead>
    <tbody>
      {{#each ai.readiness}}
      <tr><td><span class="badge {{#if this.pass}}b-good{{else}}b-crit{{/if}}">{{#if this.pass}}PASS{{else}}FAIL{{/if}}</span></td>
        <td class="tb">{{this.label}}</td><td>{{this.detail}}</td></tr>
      {{/each}}
    </tbody>
  </table>

  <div class="quote accent"><span class="qd"></span><p>{{aiVerdict}}</p></div>
  <p class="note">{{ai.methodology}} No one can guarantee an AI platform will mention or recommend any business. These optimisations significantly improve the likelihood that {{report.businessName}} is understood, trusted and surfaced by modern search and AI-powered experiences.</p>
</div>
{{/if}}

<!-- ================= GOOGLE BUSINESS PROFILE / LOCAL SEO ================= -->
{{#if local.gbpFound}}
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">◆</span><span class="sec-rule"></span><span class="sec-name">GOOGLE MAPS &amp; LOCAL SEO</span></div>
  <h2>How your Google Business Profile <span class="b">looks to a customer on the map.</span></h2>
  <p class="lead">This is the profile Google shows when someone nearby searches for what you do. Name, address and phone (NAP) consistency, review volume and rating, and how actively the profile is maintained all decide whether you appear in the local map pack.</p>

  <div class="stats">
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.blue}}">{{local.rating}}</div><div class="stat-l">Average star rating</div></div>
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.blue}}">{{formatNum local.reviewCount}}</div><div class="stat-l">Total Google reviews</div></div>
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.blue}}">{{scores.local}}</div><div class="stat-l">Local SEO score /100</div></div>
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.orangeDeep}}">{{upper local.activitySignal}}</div><div class="stat-l">Profile activity</div></div>
  </div>

  <h3 style="margin-top:22px">Your listing (NAP) as Google has it</h3>
  <table>
    <tbody>
      <tr><td style="width:26%"><b>Business name</b></td><td>{{local.name}}</td></tr>
      <tr><td><b>Address</b></td><td>{{#if local.address}}{{local.address}}{{else}}Not listed{{/if}}</td></tr>
      <tr><td><b>Phone</b></td><td>{{#if local.phone}}{{local.phone}}{{else}}Not listed{{/if}}</td></tr>
      <tr><td><b>Website on profile</b></td><td>{{#if local.website}}{{local.website}}{{#unless local.websiteMatches}} <span class="badge b-crit">MISMATCH</span>{{/unless}}{{else}}Not listed{{/if}}</td></tr>
      <tr><td><b>Category</b></td><td>{{#if local.category}}{{local.category}}{{else}}—{{/if}}</td></tr>
      <tr><td><b>Opening hours</b></td><td>{{#if local.hasHours}}Listed{{else}}<span class="badge b-crit">MISSING</span>{{/if}}</td></tr>
      <tr><td><b>Business status</b></td><td>{{#if local.businessStatus}}{{local.businessStatus}}{{else}}—{{/if}}</td></tr>
    </tbody>
  </table>

  {{#if local.reviewSummary}}
  <h3 style="margin-top:22px">What customers are saying</h3>
  <div class="quote"><span class="qd"></span><p>{{local.reviewSummary}}</p></div>
  {{/if}}

  {{#if local.reviews.length}}
  <h3 style="margin-top:18px">Recent reviews</h3>
  <table>
    <thead><tr><th style="width:22%">Reviewer</th><th style="width:10%">Rating</th><th>Review</th><th style="width:16%">When</th></tr></thead>
    <tbody>
      {{#each local.reviews}}
      <tr><td>{{this.author}}</td><td>{{this.rating}}★</td><td>{{this.text}}</td><td>{{#if this.relativeTime}}{{this.relativeTime}}{{else}}—{{/if}}</td></tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  <p class="note" style="margin-top:14px">Source: Google Places (New), {{formatMonth report.date}}. Review count, rating, NAP and hours are read live from the public Google Business Profile. "Profile activity" reflects how recently the profile has received new reviews — a maintenance signal, not a count of Google Posts.</p>
</div>
{{else}}
{{#if local.enabled}}
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">◆</span><span class="sec-rule"></span><span class="sec-name">GOOGLE MAPS &amp; LOCAL SEO</span></div>
  <h2>You're missing from the map <span class="b">where local buyers decide.</span></h2>
  <p class="lead">{{#if local.skippedNoKey}}Local SEO was selected, but the Google Places key isn't configured yet, so the map-pack data couldn't be pulled for this run.{{else}}We couldn't find a Google Business Profile for {{report.businessName}} in this location. Nearby customers searching Google Maps see your competitors, not you — and the map pack is where a large share of local buying decisions happen.{{/if}}</p>
</div>
{{/if}}
{{/if}}

<!-- ================= 07 THE STRATEGY ================= -->
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">07</span><span class="sec-rule"></span><span class="sec-name">THE STRATEGY</span></div>
  <h2>A clear plan, <span class="b">starting from a clean, credible base.</span></h2>
  <p class="lead">Three phases — clean up the spam and technical issues, build the pages that capture high-intent searches, then scale genuine authority. Sorted by impact against effort, so you see movement while the slower work compounds.</p>

  <h3>Your first 30 days</h3>
  {{#each roadmap.phase1}}
  <div class="step avoid"><div class="step-n">{{inc @index}}</div>
    <div><div class="step-t">{{this.title}}</div><div class="step-d">{{this.detail}}</div></div></div>
  {{/each}}

  <h3>Days 30–60 — build</h3>
  {{#each roadmap.phase2}}
  <div class="step avoid"><div class="step-n" style="background:{{../settings.colors.blue}}">{{inc @index}}</div>
    <div><div class="step-t">{{this.title}}</div><div class="step-d">{{this.detail}}</div></div></div>
  {{/each}}

  <h3>Days 60–90 — scale</h3>
  {{#each roadmap.phase3}}
  <div class="step avoid"><div class="step-n" style="background:{{../settings.colors.orange}};color:{{../settings.colors.navy}}">{{inc @index}}</div>
    <div><div class="step-t">{{this.title}}</div><div class="step-d">{{this.detail}}</div></div></div>
  {{/each}}
</div>

<!-- ================= 08 THE FIX, MEASURED ================= -->
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">08</span><span class="sec-rule"></span><span class="sec-name">THE FIX, MEASURED</span></div>
  <h2>We report on outcomes, <span class="b">not activity.</span></h2>
  <p class="lead">You'll never get a vague "we did some SEO" update. Every month you see exactly where these numbers stand and how far they've moved. These are the metrics we own together.</p>

  <div class="kpi">
    {{#each kpis}}
    <div class="kpi-c"><div class="kpi-l">{{upper this.label}}</div>
      <div class="kpi-v"><span class="kpi-f">{{this.from}}</span> → <span class="kpi-t">{{this.to}}</span></div>
      <div class="kpi-bar"><div class="kpi-fill" style="width:{{this.pct}}%"></div></div></div>
    {{/each}}
  </div>

  <p class="note">Targets are directional based on the strategy and current data; actual results depend on execution, budget for quality backlinks, and market conditions.</p>

  <h3 style="margin-top:26px">Why {{settings.companyShort}}</h3>
  <div class="stats">
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.orangeDeep}}">13+</div><div class="stat-l">Years in digital marketing</div></div>
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.orangeDeep}}">250+</div><div class="stat-l">Clients worldwide</div></div>
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.orangeDeep}}">60+</div><div class="stat-l">In-house specialists</div></div>
    <div class="stat"><div class="stat-v" style="color:{{settings.colors.orangeDeep}}">1:1</div><div class="stat-l">Direct access to your strategist</div></div>
  </div>
</div>

<!-- ================= 09 YOUR INVESTMENT ================= -->
{{#if pricing.enabled}}
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">09</span><span class="sec-rule"></span><span class="sec-name">YOUR INVESTMENT</span></div>
  <h2>Simple pricing. <span class="b">Serious results.</span></h2>
  <p class="lead">{{pricing.intro}} Prices in {{pricing.currency}}.</p>

  <div class="price-grid">
    {{#each pricing.packages}}
    <div class="pk {{#if this.recommended}}feat{{/if}} avoid">
      {{#if this.recommended}}<div class="pk-tab">{{this.badge}}</div>{{/if}}
      <div class="pk-name">{{this.name}}</div>
      <div class="pk-price">{{../pricing.symbol}}{{this.price}}<span class="pk-per">{{this.period}}</span></div>
      {{#if this.oldPrice}}<div class="pk-old">{{../pricing.symbol}}{{this.oldPrice}}{{this.period}}</div>{{/if}}
      {{#if this.blurb}}<div class="pk-blurb">{{this.blurb}}</div>{{/if}}
      <ul class="pk-f">
        {{#each this.features}}<li>{{this}}</li>{{/each}}
        {{#each this.starFeatures}}<li class="star">{{this}}</li>{{/each}}
      </ul>
    </div>
    {{/each}}
  </div>

  {{#if pricing.note}}<div class="nb">{{pricing.note}}</div>{{/if}}

  {{#if pricing.guaranteeTitle}}
  <div class="risk avoid">
    <div class="risk-i">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="{{settings.colors.orange}}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <path d="M9 12l2 2 4-4"/>
      </svg>
    </div>
    <div>
      <div class="risk-t">{{pricing.guaranteeTitle}}</div>
      <div class="risk-b">{{pricing.guaranteeBody}}</div>
    </div>
  </div>
  {{/if}}
</div>
{{/if}}

<!-- ================= 10 LET'S BEGIN ================= -->
<div class="page">
  <div class="sec-head"><span class="sec-dia"></span><span class="sec-num">{{#if pricing.enabled}}10{{else}}09{{/if}}</span><span class="sec-rule"></span><span class="sec-name">LET'S BEGIN</span></div>
  <h2>Ready when you are. <span class="b">Let's get customers finding you.</span></h2>
  <p class="lead">Onboarding is simple and fast — you could have work underway within 24 hours of saying yes.</p>

  {{#each onboarding}}
  <div class="step avoid"><div class="step-n">{{inc @index}}</div>
    <div><div class="step-t">{{this.t}}</div><div class="step-d">{{this.d}}</div></div></div>
  {{/each}}

  <div class="cta">
    <div class="cta-e">LET'S BEGIN</div>
    <h3>This report is free. The next 90 days are the decision.</h3>
    <p>Everything in this analysis is fixable, and most of it quickly. Reply and we'll walk you through the plan for {{report.domain}} — no obligation.</p>
    <div class="cta-b">Reply "Let's go" to begin</div>
    <div class="cta-s">{{report.agentName}} · {{report.agentDesignation}} · {{settings.companyName}}<br>
      {{#if report.agentPhone}}{{report.agentPhone}} · {{/if}}{{#if report.agentEmail}}{{report.agentEmail}}{{else}}{{settings.email}}{{/if}} · {{settings.website}}</div>
  </div>

  <div class="note" style="text-align:center">Data valid as of {{formatDate report.date}}. Rankings and AI results shift weekly — this snapshot has a shelf life of about {{report.validDays}} days.</div>
</div>

</body>
</html>
